# ============================================================
# VoxControl -- environment variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Language ---
# Options: pt-BR | pt-PT | es-ES | es-MX | en-US | en-GB
# Short codes also accepted: pt | es | en
APP_LANGUAGE=pt-BR

# --- AI (at least one key recommended) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# --- AI backend preference ---
# Options: "claude" | "openai" | "offline"
AI_BACKEND=claude

# --- Models ---
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# --- Remote server ---
REMOTE_SERVER_HOST=0.0.0.0
REMOTE_SERVER_PORT=8765
# Leave empty for plain HTTP; fill paths for HTTPS (recommended for phone mic)
SSL_CERTFILE=
SSL_KEYFILE=

# --- Whisper (STT) ---
# Options: tiny, base, small, medium, large-v3
WHISPER_MODEL=small
# Language: auto-set from APP_LANGUAGE. Override only if needed.
# WHISPER_LANGUAGE=pt

# --- Wake word ---
# Auto-set from APP_LANGUAGE: pt=computador, es=computadora, en=computer
# Override only if you want a custom wake word.
# WAKE_WORD=computador
# Listen time after wake word (seconds)
LISTEN_TIMEOUT=5

# --- Behavior ---
# Voice responses: true | false
VOICE_RESPONSE=true
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
