# ============================================================
# voz-controle-pt — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- IA (pelo menos uma chave é necessária) ---
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
OPENAI_API_KEY=sua_chave_openai_aqui

# --- Preferência de backend de IA ---
# Opções: "claude" | "openai" | "offline"
AI_BACKEND=claude

# --- Modelos ---
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# --- Servidor remoto ---
REMOTE_SERVER_HOST=0.0.0.0
REMOTE_SERVER_PORT=8765
# Deixe vazio para HTTP simples; preencha caminhos para HTTPS (recomendado para microfone no celular)
SSL_CERTFILE=
SSL_KEYFILE=

# --- Whisper ---
# Opções: tiny, base, small, medium, large-v3
WHISPER_MODEL=small
WHISPER_LANGUAGE=pt

# --- Wake word ---
WAKE_WORD=computador
# Tempo de escuta após wake word (segundos)
LISTEN_TIMEOUT=5

# --- Comportamento ---
# Responder por voz: true | false
VOICE_RESPONSE=true
# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
